flowchart TD
  Click["User clicks 'New Issue'\nweb/src/components/document-tabs/WeekIssuesTab.tsx"] --> IssuesList["IssuesList builds belongs_to context\nweb/src/components/IssuesList.tsx"]
  IssuesList --> Mutation["useCreateIssue().mutateAsync\nweb/src/hooks/useIssuesQuery.ts"]
  Mutation --> ApiClient["apiPost('/api/issues')\nweb/src/lib/api.ts"]
  ApiClient --> Proxy["Vite dev proxy / browser fetch\nweb/vite.config.ts"]
  Proxy --> Middleware["helmet -> rate limit -> cors -> parsers -> cookie/session -> conditional CSRF -> authMiddleware\napi/src/app.ts"]
  Middleware --> Route["POST /api/issues\napi/src/routes/issues.ts"]
  Route --> Tx["BEGIN + advisory lock + next ticket number"]
  Tx --> Insert["INSERT INTO documents\n(document_type = 'issue')"]
  Insert --> Assoc["INSERT INTO document_associations\nfor belongs_to[]"]
  Assoc --> Commit["COMMIT"]
  Commit --> Hydrate["getBelongsToAssociations + extractIssueFromRow"]
  Hydrate --> Response["201 JSON issue response"]
  Response --> Cache["React Query optimistic row replaced,\nthen issue list invalidated"]
  Cache --> Navigate["navigate('/documents/:id')"]
