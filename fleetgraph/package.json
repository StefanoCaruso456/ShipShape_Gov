{
  "name": "@ship/fleetgraph",
  "version": "0.0.0",
  "private": true,
  "description": "FleetGraph shared LangGraph runtime and supervisor foundations",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
