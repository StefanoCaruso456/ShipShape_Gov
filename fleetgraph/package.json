  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.62.0",
    "@langchain/core": "^1.1.16",
    "@langchain/langgraph": "^1.0.2",
    "@ship/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.3",
    "typescript": "^5.7.2",
    "vitest": "^4.0.16"
  }
